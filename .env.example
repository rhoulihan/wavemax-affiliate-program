# WaveMAX Laundry Affiliate Program - Example Configuration
# Copy this file to .env and update with your actual values

# Server Configuration
PORT=3000
NODE_ENV=development
ENABLE_DELETE_DATA_FEATURE=false
BAG_FEE=10.00

# Background (cron) jobs — HA gating. Set 'true' on EXACTLY ONE (leader)
# instance so payment-verification / reminder jobs run once; leave unset or
# 'false' on every other instance to avoid double execution. Strict match:
# only the exact string 'true' enables. See docs/ops/HA-PHASE1-WEB.md.
RUN_BACKGROUND_JOBS=true

# W-9 encrypted document store (PR 10). Root directory for AES-256-GCM
# encrypted W-9 files (dirs 0700, files 0600). In production this is the
# DRBD-replicated volume — must be writable on whichever box serves the
# upload (single-primary: pin /api/v1/w9 + the registration upload route
# to the primary, or use a shared/replicated read-write mount).
W9_STORAGE_PATH=/var/lib/wavemax/w9

# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017/wavemax
# For MongoDB Atlas: Use your connection string
MONGODB_URI=mongodb://localhost:27017/wavemax

# Security Keys - IMPORTANT: Generate new keys for production!
# You can generate these using: openssl rand -hex 32
ENCRYPTION_KEY=your_encryption_key_here
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here
# Optional dedicated secret for the csrf-csrf double-submit token. Falls back
# to SESSION_SECRET, then JWT_SECRET, if not set. Setting a separate value is
# recommended so CSRF can be rotated without invalidating live sessions or JWTs.
CSRF_SECRET=your_csrf_secret_here

# Default Administrator Account
DEFAULT_ADMIN_EMAIL=admin@example.com

# Email Configuration - Choose one provider:

# Option 1: Console (for development/testing)
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@example.com

# Option 2: SMTP
#EMAIL_PROVIDER=smtp
#EMAIL_HOST=smtp.example.com
#EMAIL_PORT=587
#EMAIL_USER=your_email@example.com
#EMAIL_PASS=your_email_password
#EMAIL_FROM=noreply@example.com
#EMAIL_SECURE=false

# Option 3: Microsoft Exchange
#EMAIL_PROVIDER=exchange
#EXCHANGE_HOST=mail.example.com
#EXCHANGE_PORT=587
#EXCHANGE_USER=your_exchange_user
#EXCHANGE_PASS=your_exchange_password
#EXCHANGE_FROM_EMAIL=noreply@example.com
#EXCHANGE_REJECT_UNAUTHORIZED=true

# Alert Email for Monitoring (optional)
#ALERT_EMAIL=ops-team@example.com

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Base URL for the API
BASE_URL=http://localhost:3000

# Frontend URL (for password reset links, etc.)
FRONTEND_URL=http://localhost:3000

# Logging Configuration
LOG_LEVEL=debug
LOG_DIR=logs

# Stripe API Keys (Optional - for payment processing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# AWS S3 Configuration (Optional - for storing bag barcodes)
AWS_S3_BUCKET=your-s3-bucket-name

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
RELAX_RATE_LIMITING=false

# Additional Settings
TRUST_PROXY=false
COOKIE_SECURE=false
CSRF_PHASE=3
SHOW_DOCS=true

# Service Area Configuration
SERVICE_STATE=TX
SERVICE_CITY=Austin
SERVICE_RADIUS_MILES=50

# Austin reference build — Google Places (browser-direct reviews fetch).
# The key is rendered into the browser by /assets/js/austin-host-mock-config.js
# at request time, so abuse is bounded by HTTP-referrer restrictions on the
# key itself — configure these in Google Cloud Console:
#   API restrictions:    Places API (New) only
#   Application restr.:  HTTP referrers (websites)
#                        https://wavemax.promo/*
#                        https://*.wavemax.promo/*
#                        https://wavemaxlaundry.com/*
#                        https://*.wavemaxlaundry.com/*
#                        http://localhost:*/*  (dev only)
#                        http://127.0.0.1:*/*  (dev only)
GOOGLE_PLACES_API_KEY=
# Place ID for THIS franchisee (the value Hibu, Yext, and Google Maps all
# resolve to "WaveMAX Laundry · 825 E Rundberg Ln F1, Austin, TX 78753").
# Find via Places API "Find Place from Text" or by searching the location
# on Google Maps and copying the `ChIJ...` token from the share URL.
GOOGLE_PLACES_LOCATION_PLACE_ID=
# Legacy alias — kept until any consumer of LOCATION_AUSTIN_TX_PLACE_ID is
# migrated. New code should read GOOGLE_PLACES_LOCATION_PLACE_ID instead.
LOCATION_AUSTIN_TX_PLACE_ID=

# Contact-form recipient — sourced from LOCATION_DATA, NOT env.
# server/controllers/contactController reads
# loadLocationData(slug).contact.email at runtime via the loader at
# server/config/locationData.js, which sandbox-evaluates the same
# IIFE the browser loads (public/assets/js/austin-host-mock-data.js
# for slug 'austin-tx'). To change where contact-form messages are
# sent, edit LOCATION_DATA.contact.email in that file. No env var
# is involved.
# ── Location quarantine ─────────────────────────────────────────────
# When 'true', this server only serves Austin location pages
# (/austin-tx/*), the affiliate-program app (API, embed pages, assets,
# legal pages), and the contact endpoint. All other requests
# 302-redirect to the corporate site (CORPORATE_SITE_URL), preserving
# the original path. Leave unset/false in local dev and tests.
QUARANTINE_NON_AUSTIN=false
# Target for quarantine redirects. Trailing slashes are stripped.
CORPORATE_SITE_URL=https://www.wavemaxlaundry.com

# ── Design Explorer (private franchisor review tool) ────────────────
# Shared access token gating /design-explorer/* (server/middleware/
# explorerGuard.js). Without a matching ?k=<token> (or explorer_k cookie)
# the explorer 404s and is noindex'd. Use a long random string; share
# https://rundberglaundry.com/design-explorer/index.html?k=<token>
# with reviewers. Leave unset to disable the tool entirely.
EXPLORER_TOKEN=
# API key for the live FAQ concierge (POST /api/concierge, Claude Haiku).
# When unset the concierge gracefully declines; the explorer still works.
ANTHROPIC_API_KEY=
