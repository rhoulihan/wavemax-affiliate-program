{
  "name": "wavemax-affiliate-program",
  "version": "1.0.0",
  "description": "WaveMAX Laundry Affiliate Program for Wash, Dry, Fold Services",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:assets": "node scripts/build-assets.js",
    "test": "TZ=America/Chicago jest --runInBand --forceExit",
    "test:unit": "TZ=America/Chicago jest tests/unit --runInBand --forceExit",
    "test:integration": "TZ=America/Chicago jest tests/integration --runInBand --forceExit",
    "test:coverage": "TZ=America/Chicago jest --coverage --runInBand --forceExit",
    "test:watch": "TZ=America/Chicago jest --watch",
    "test:all": "./tests/runAllTests.sh",
    "test:memory": "TZ=America/Chicago NODE_OPTIONS='--max-old-space-size=512' jest --runInBand --forceExit",
    "test:memory:batch": "./tests/runMemoryOptimizedTests.sh",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "generate:sample-data": "node scripts/setup/generate-sample-data.js",
    "setup:database": "node scripts/setup/setup-database.js",
    "init:defaults": "node scripts/setup/init-defaults.js",
    "ensure-indexes": "node scripts/ensure-indexes.js",
    "generate:sample-data:clean": "node scripts/setup/generate-sample-data.js --clean",
    "build:explorer": "node design-explorer/build.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/wavemax-affiliate-program.git"
  },
  "keywords": [
    "laundry",
    "affiliate",
    "wavemax",
    "wash-dry-fold",
    "pickup-delivery"
  ],
  "author": "CRHS Enterprises, LLC",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "axios": "^1.9.0",
    "compression": "^1.8.1",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.5",
    "crypto-js": "^4.2.0",
    "csrf-csrf": "^4.0.3",
    "csv-writer": "^1.6.0",
    "dotenv": "16.3.1",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "7.1.4",
    "express-session": "^1.18.1",
    "express-validator": "^7.0.1",
    "helmet": "7.1.0",
    "imapflow": "^1.0.205",
    "joi": "17.11.0",
    "jsonwebtoken": "9.0.2",
    "mailparser": "^3.7.4",
    "mongoose": "^8.15.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.1.0",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1",
    "winston": "^3.10.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@playwright/test": "^1.59.1",
    "csso": "^5.0.5",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "jsdom": "^26.1.0",
    "mongodb-memory-server": "^10.1.4",
    "node-mocks-http": "^1.17.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "terser": "^5.48.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
